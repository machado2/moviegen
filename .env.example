# Copy to .env and adjust as needed. .env is gitignored — never commit secrets.

# Absolute path for all project data. Defaults to ./data relative to cwd if unset.
# Using an absolute path outside the repo prevents data loss on git clean / reinstalls.
DATA_DIR=/shared/mediagen

# ─── LLM gateway (LiteLLM, OpenAI-compatible) ────────────────────────────────
# All model calls go through the single gateway, which holds the real provider
# keys. It's a drop-in for OpenRouter (same /chat/completions API and model
# names). Apps only need the base URL + the single gateway key.
#
# Default base is the public endpoint (mediagen runs on the LAN minipc). On-box,
# inside the homeops docker network, use http://homeops-litellm:4000/v1
LLM_BASE_URL=https://llm.fbmac.net/v1
# Single gateway key (LiteLLM master key). If set, it's used as-is and the
# Settings UI shows the key as env-provided (not editable). If unset, the key is
# read from whatever was saved via the Settings panel.
LLM_API_KEY=sk-...
