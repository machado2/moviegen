{
  "name": "@mediagen/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "mkdir -p ../dist/comics/assembly && cp src/comics/assembly/*.py ../dist/comics/assembly/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node ../dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.3",
    "@mediagen/types": "*",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "fastify": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^6.0.3",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
